#############
# Lake core #
#############

# Lake plugin dir, absolute path or relative path
PLUGIN_DIR=bin/plugins

# Lake Database Connection String
DB_URL=mysql://merico:merico@mysql:3306/lake?charset=utf8mb4&parseTime=True&loc=UTC
E2E_DB_URL=mysql://merico:merico@mysql:3306/lake_test?charset=utf8mb4&parseTime=True&loc=UTC
# Silent Error Warn Info
DB_LOGGING_LEVEL=Error

# Lake REST API
PORT=8080
MODE=release

NOTIFICATION_ENDPOINT=
NOTIFICATION_SECRET=

API_TIMEOUT=120s
API_RETRY=3
API_REQUESTS_PER_HOUR=10000
PIPELINE_MAX_PARALLEL=1
# Debug Info Warn Error
LOGGING_LEVEL=
LOGGING_DIR=./logs
ENABLE_STACKTRACE=false
FORCE_MIGRATION=false

##########################
# Sensitive information encryption key
##########################
ENCRYPTION_SECRET=

##########################
# Set if skip verify and connect with out trusted certificate when use https
##########################
IN_SECURE_SKIP_VERIFY=

##########################
# Grafana-only settings
# These settings configure the Grafana container for password reset email.
# Do not put GF_SMTP_PASSWORD in this shared .env file; devlake/config-ui
# also load .env through env_file and would receive the same secret.
##########################
# Must be the public URL users open in the browser.
# Leave blank to use the Docker Compose local default: http://localhost:4000/grafana
# Production example:
# GF_SERVER_ROOT_URL=https://your-domain.example.com/grafana
GF_SERVER_ROOT_URL=
# Enable SMTP to let Grafana send password reset emails.
GF_SMTP_ENABLED=false
# SMTP host must include port, for example smtp.example.com:587 or smtp.example.com:465.
GF_SMTP_HOST=
GF_SMTP_USER=
# GF_SMTP_PASSWORD= # DO NOT set a real value here; export it in the shell before
# running docker compose or inject it through deployment secrets for Grafana only.
GF_SMTP_FROM_ADDRESS=
GF_SMTP_FROM_NAME=Grafana
# Typical values: MandatoryStartTLS for port 587, empty for implicit TLS on port 465.
GF_SMTP_STARTTLS_POLICY=
# Keep false unless IT uses a private/self-signed SMTP certificate.
GF_SMTP_SKIP_VERIFY=false

##########################
# Set SKIP_COMMIT_FILES to 'false' to enable file collection. Any other value or absence of this parameter will skip collection.
##########################
# SKIP_COMMIT_FILES=true
