      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  commit_date AS \"Date\",\n  repo_name AS \"Repository\",\n  commit_sha AS \"Commit SHA\",\n  tab_lines_added AS \"Tab Lines\",\n  composer_lines_added AS \"Composer Lines\",\n  manual_lines_added AS \"Manual Lines\",\n  ROUND(\n    (tab_lines_added+composer_lines_added)\n    / NULLIF(tab_lines_added+composer_lines_added+manual_lines_added, 0) * 100\n  , 1) AS \"AI Share %\"\nFROM _tool_cursor_commit_ai_share\nWHERE $__timeFilter(commit_date)\nORDER BY tab_lines_added+composer_lines_added DESC\nLIMIT 50",
          "refId": "A"
        }
