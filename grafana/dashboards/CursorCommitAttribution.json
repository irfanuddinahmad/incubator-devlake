          "rawSql": "SELECT commit_date AS time,\n  SUM(tab_lines_added) AS \"Tab Completion\",\n  SUM(composer_lines_added) AS \"Composer\",\n  SUM(manual_lines_added) AS \"Manual\"\nFROM _tool_cursor_commit_ai_share\nWHERE $__timeFilter(commit_date)\nGROUP BY commit_date\nORDER BY commit_date",
