        "showHeader": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  repo_name AS \"Repository\",\n  COUNT(DISTINCT commit_sha) AS \"Commits\",\n  SUM(tab_lines_added) AS \"Tab Lines\",\n  SUM(composer_lines_added) AS \"Composer Lines\",\n  SUM(manual_lines_added) AS \"Manual Lines\",\n  ROUND(\n    (SUM(tab_lines_added)+SUM(composer_lines_added))\n    / NULLIF(SUM(tab_lines_added)+SUM(composer_lines_added)+SUM(manual_lines_added), 0) * 100\n  , 1) AS \"AI Share %\"\nFROM _tool_cursor_commit_ai_share\nWHERE $__timeFilter(commit_date)\nGROUP BY repo_name\nORDER BY SUM(tab_lines_added)+SUM(composer_lines_added) DESC",
          "refId": "A"
        }
      ],
      "title": "AI Code Share by Repository",
      "type": "table"
    },
