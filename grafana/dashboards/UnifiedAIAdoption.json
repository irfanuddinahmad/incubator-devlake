      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT UPPER(provider) AS \"Provider\",\n  COUNT(DISTINCT NULLIF(user_email, '')) AS \"Unique Users\",\n  SUM(lines_added) AS \"Lines Added\",\n  SUM(prs_created + commits_created) AS \"Commits & PRs\",\n  SUM(suggestions_count) AS \"Suggestions\",\n  ROUND(SUM(estimated_cost_usd), 2) AS \"Total Spend (USD)\",\n  ROUND(SUM(estimated_cost_usd) / NULLIF(SUM(lines_added), 0), 4) AS \"Cost per Line (USD)\"\nFROM ai_activities\nWHERE $__timeFilter(date)\nGROUP BY provider\nORDER BY SUM(estimated_cost_usd) DESC",
          "refId": "A"
        }
      ],
      "title": "Cross-Tool AI Comparison",
      "type": "table"
