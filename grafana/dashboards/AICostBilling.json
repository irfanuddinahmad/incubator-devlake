          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date AS time,\n  ROUND(\n    SUM(cache_read_tokens) / NULLIF(SUM(cache_read_tokens)+SUM(cache_creation_tokens), 0) * 100\n  , 1) AS \"Cache Hit Rate %\"\nFROM _tool_claude_usage\nWHERE $__timeFilter(date)\nGROUP BY date\nORDER BY date",
          "refId": "A"
        }
      ],
