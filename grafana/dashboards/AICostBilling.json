      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date AS time,\n  CASE\n    WHEN model LIKE '%sonnet%' OR model LIKE '%Sonnet%' THEN 'Sonnet'\n    WHEN model LIKE '%opus%'   OR model LIKE '%Opus%'   THEN 'Opus'\n    WHEN model LIKE '%haiku%'  OR model LIKE '%Haiku%'  THEN 'Haiku'\n    ELSE COALESCE(NULLIF(model,''), 'Unknown')\n  END AS metric,\n  SUM(estimated_cost_usd) AS value\nFROM _tool_claude_usage\nWHERE $__timeFilter(date)\nGROUP BY date, metric\nORDER BY date",
          "refId": "A"
        }
      ],
      "title": "Claude Daily Cost by Model",
      "type": "timeseries"
    },
    {
      "datasource": "mysql",
      "description": "Ratio of cache_read_tokens / (cache_read_tokens + cache_creation_tokens). Higher = better prompt reuse and lower cost.",
