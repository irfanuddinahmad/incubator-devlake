      "targets": [
        {
          "datasource": "mysql",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(NULLIF(model,''), 'Unknown') AS \"Model\",\n  COALESCE(NULLIF(kind,''), 'Unknown') AS \"Billing Kind\",\n  COUNT(*) AS \"Requests\",\n  SUM(CASE WHEN max_mode=1 THEN 1 ELSE 0 END) AS \"Max Mode Reqs\",\n  SUM(input_tokens) AS \"Input Tokens\",\n  SUM(output_tokens) AS \"Output Tokens\",\n  SUM(cache_read_tokens) AS \"Cache Read\",\n  ROUND(SUM(charged_cents)/100, 4) AS \"Charged (USD)\",\n  ROUND(SUM(total_cents)/100, 4) AS \"Total Before Credits (USD)\"\nFROM _tool_cursor_usage_events\nWHERE $__timeFilter(timestamp)\nGROUP BY model, kind\nORDER BY SUM(charged_cents) DESC",
          "refId": "A"
        }
      ],
      "title": "Cursor Cost Breakdown by Model & Kind",
      "type": "table"
