          "rawQuery": true,
          "rawSql": "SELECT COALESCE(NULLIF(model,''), 'Unknown') AS \"Model\",\n  SUM(edit_tool_accepted) AS \"Edit Acc\",\n  SUM(edit_tool_rejected) AS \"Edit Rej\",\n  SUM(write_tool_accepted) AS \"Write Acc\",\n  SUM(write_tool_rejected) AS \"Write Rej\",\n  SUM(multi_edit_tool_accepted) AS \"Multi-Edit Acc\",\n  SUM(notebook_edit_tool_accepted) AS \"Notebook Acc\",\n  ROUND(\n    (SUM(edit_tool_accepted)+SUM(multi_edit_tool_accepted)+SUM(write_tool_accepted)+SUM(notebook_edit_tool_accepted))\n    / NULLIF(\n        SUM(edit_tool_accepted)+SUM(edit_tool_rejected)+SUM(multi_edit_tool_accepted)+SUM(multi_edit_tool_rejected)\n        +SUM(write_tool_accepted)+SUM(write_tool_rejected)+SUM(notebook_edit_tool_accepted)+SUM(notebook_edit_tool_rejected)\n      , 0) * 100, 1\n  ) AS \"Overall Acc %\",\n  SUM(cache_read_tokens) AS \"Cache Read Tokens\",\n  ROUND(SUM(cache_read_tokens) / NULLIF(SUM(cache_read_tokens)+SUM(cache_creation_tokens), 0) * 100, 1) AS \"Cache Hit %\"\nFROM _tool_claude_usage\nWHERE $__timeFilter(date)\nGROUP BY model\nORDER BY SUM(edit_tool_accepted)+SUM(write_tool_accepted) DESC",
