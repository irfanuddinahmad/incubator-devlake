      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date AS time,\n  CASE\n    WHEN model LIKE '%sonnet%' OR model LIKE '%Sonnet%' THEN 'Sonnet'\n    WHEN model LIKE '%opus%'   OR model LIKE '%Opus%'   THEN 'Opus'\n    WHEN model LIKE '%haiku%'  OR model LIKE '%Haiku%'  THEN 'Haiku'\n    ELSE COALESCE(NULLIF(model,''), 'Unknown')\n  END AS metric,\n  SUM(estimated_cost_usd) AS value\nFROM ai_activities\nWHERE $__timeFilter(date)\n  AND provider = 'claude'\nGROUP BY date, metric\nORDER BY date",
          "refId": "A"
        }
      ],
      "title": "Cost Efficiency \u2013 Model Spend Breakdown",
      "transformations": [
        {
          "id": "prepareTimeSeries",
          "options": {
            "format": "many"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^value (.+)$",
            "renamePattern": "$1"
          }
        }
      ],
      "type": "timeseries"
    },
